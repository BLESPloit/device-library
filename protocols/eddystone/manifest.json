{
  "name": "Eddystone",
  "version": 1,
  "vars": "vars.json",
  "assets": {
    "icon": "assets/eddystone.svg",
    "graphics": "assets/graphics.json"
  },
  "roles": {
    "observer": {
      "entry": "observer/adv_decode.lua",
      "scan_conditions": {
        "service_data_uuid_16": "feaa"
      },
      "_comment": "Service data AD 0x16 for UUID 0xFEAA per https://github.com/google/eddystone/blob/master/protocol-specification.md",
      "priority": 45
    },
    "peripheral": {
      "entry": "peripheral/eddystone_url_peripheral.lua",
      "advertisement": "peripheral/adv.json",
      "interface": "peripheral/interface.json",
      "show_adv_address": true
    }
  },
  "manifest_version": 1
}
