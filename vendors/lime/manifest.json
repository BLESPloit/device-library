{
  "name": "Lime Scooters",
  "description": "Lime shared e-scooter BLE advertising fingerprint",
  "version": 1,
  "assets": {
    "icon": "assets/lime_logo.svg"
  },
  "roles": {
    "observer": {
      "entry": "observer/adv_decode.lua",
      "priority": 45,
      "scan_conditions": {
        "device_name_regex": "^lime-[0-9]+$"
      }
    }
  },
  "manifest_version": 1
}
