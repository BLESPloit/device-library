{
  "name": "Apple Find My",
  "assets": {
    "icon": "assets/apple.svg",
    "icon_tint": "#30D158"
  },
  "roles": {
    "observer": {
      "entry": "observer/adv_decode.lua",
      "scan_conditions": {
        "fingerprint_has_entry_id": "apple_meta",
        "fingerprint_entry_attributes": {
          "continuity_has_findmy": "true"
        }
      },
      "priority": 30
    }
  },
  "manifest_version": 1,
  "version": 1
}
